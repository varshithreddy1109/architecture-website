# Copy this file to .env.local and fill in your Supabase project credentials.
# These are safe to expose to the browser (NEXT_PUBLIC_) — Supabase's anon key
# is designed for client-side use and is protected by Row Level Security (RLS)
# once policies are configured in a later stage.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
